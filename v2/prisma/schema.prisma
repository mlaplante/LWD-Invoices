generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  clients    Client[]
  currencies Currency[]
  taxes      Tax[]
  items      Item[]
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  firstName String?
  lastName  String?
  role      UserRole @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  STAFF
}

model Client {
  id               String   @id @default(cuid())
  name             String
  email            String?
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  country          String?
  taxId            String?
  notes            String?
  portalToken      String   @unique @default(cuid())
  portalPassphrase String?
  isArchived       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Currency {
  id             String   @id @default(cuid())
  code           String
  name           String
  symbol         String
  symbolPosition String   @default("before")
  exchangeRate   Decimal  @default(1) @db.Decimal(18, 6)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
}

model Tax {
  id             String   @id @default(cuid())
  name           String
  rate           Decimal  @db.Decimal(8, 4)
  isCompound     Boolean  @default(false)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Item {
  id             String   @id @default(cuid())
  name           String
  description    String?
  rate           Decimal? @db.Decimal(18, 6)
  unit           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
