// ─── Email Delivery Events (Resend webhook ingestion) ─────────────────────────

model EmailEvent {
  id             String   @id @default(cuid())
  // Resend message id from the original send response and the webhook payload.
  resendId       String
  // Raw event type from Resend, e.g. "email.delivered" / "email.opened" / "email.clicked".
  type           String
  occurredAt     DateTime
  recipient      String
  // Populated only on click events.
  link           String?
  // Resolved from the `org_id` tag on the original send. Optional because we may
  // ingest events for emails sent before tagging was wired in.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  // Resolved from the `invoice_id` tag on the original send. Optional because not
  // every email relates to an invoice (e.g. scheduled reports) and legacy sends
  // predate the tag. Powers the per-invoice engagement timeline and the
  // "viewed but unpaid" reminder trigger.
  invoiceId      String?
  invoice        Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([resendId])
  @@index([organizationId, type, occurredAt])
  @@index([invoiceId, occurredAt])
}

// ─── Scheduled Reports ───────────────────────────────────────────────────────

model ScheduledReport {
  id              String          @id @default(cuid())
  reportType      ReportType
  frequency       ReportFrequency
  dayOfWeek       Int?            // 0=Sunday...6=Saturday (for WEEKLY)
  dayOfMonth      Int?            // 1-28 (for MONTHLY/QUARTERLY)
  recipients      String[]        // email addresses
  enabled         Boolean         @default(true)
  lastSentAt      DateTime?

  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
  @@index([enabled])
}

// ─── Reminder Sequences ──────────────────────────────────────────────────────

model ReminderSequence {
  id              String   @id @default(cuid())
  name            String
  isDefault       Boolean  @default(false)
  enabled         Boolean  @default(true)

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  steps           ReminderStep[]
  invoices        Invoice[]

  createdAt       DateTime @default(now())

  @@index([organizationId])
}

model ReminderStep {
  id                  String   @id @default(cuid())
  // How this step is scheduled. DUE_DATE_OFFSET uses daysRelativeToDue; VIEWED_UNPAID
  // fires once the invoice email has been opened and remains unpaid (see viewedDelayHours).
  trigger             ReminderStepTrigger @default(DUE_DATE_OFFSET)
  daysRelativeToDue   Int      // negative = before due, 0 = on due, positive = after due (DUE_DATE_OFFSET only)
  // For VIEWED_UNPAID steps: hours to wait after the first open before nudging.
  viewedDelayHours    Int?
  subject             String
  body                String
  sort                Int      @default(0)

  sequenceId          String
  sequence            ReminderSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  logs                ReminderLog[]

  createdAt           DateTime @default(now())

  @@index([sequenceId])
}

model ReminderLog {
  id         String   @id @default(cuid())
  sentAt     DateTime @default(now())

  stepId     String
  step       ReminderStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  invoiceId  String
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([stepId, invoiceId])   // prevents double-sends
  @@index([invoiceId])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
