// ─── Retainers / Deposits ────────────────────────────────────────────────────

model Retainer {
  id             String   @id @default(cuid())
  balance        Decimal  @default(0) @db.Decimal(20, 10)
  clientId       String   @unique
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions   RetainerTransaction[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clientId, organizationId])
}

model RetainerTransaction {
  id          String   @id @default(cuid())
  type        String   // "deposit" | "drawdown" | "refund"
  amount      Decimal  @db.Decimal(20, 10)
  description String?
  method      String?
  retainerId  String
  retainer    Retainer @relation(fields: [retainerId], references: [id], onDelete: Cascade)
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

enum HoursRetainerResetInterval {
  MONTHLY
}

enum HoursRetainerPeriodStatus {
  ACTIVE
  CLOSED
}

model HoursRetainer {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name           String
  includedHours  Decimal  @db.Decimal(16, 8)
  resetInterval  HoursRetainerResetInterval?
  hourlyRate     Decimal? @db.Decimal(20, 10)
  active         Boolean  @default(true)

  periods        HoursRetainerPeriod[]
  timeEntries    TimeEntry[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, clientId])
}

model HoursRetainerPeriod {
  id                    String   @id @default(cuid())
  retainerId            String
  retainer              HoursRetainer @relation(fields: [retainerId], references: [id], onDelete: Cascade)

  label                 String
  periodStart           DateTime
  periodEnd             DateTime
  includedHoursSnapshot Decimal  @db.Decimal(16, 8)
  status                HoursRetainerPeriodStatus @default(ACTIVE)

  timeEntries           TimeEntry[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([retainerId, status])
}

// ─── Client Retention / Check-In Automation ───────────────────────────────────
// Surfaces a weekly admin-reviewed queue of relationship touches (thank-you,
// 30-day check-in, quarterly, annual). The system only queues the reminder —
// the admin writes the actual message — so the relationship still feels human.

model ClientCheckIn {
  id              String                 @id @default(cuid())
  organizationId  String
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Optional project anchor — PROJECT_CLOSE / THIRTY_DAY / ANNUAL touches are
  // tied to a specific project; QUARTERLY is a client-level rhythm.
  projectId       String?
  project         Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)

  touchType       ClientCheckInTouchType
  status          ClientCheckInStatus    @default(PENDING)
  dueAt           DateTime
  outcome         ClientCheckInOutcome?
  notes           String?
  completedAt     DateTime?
  dismissedAt     DateTime?
  snoozedUntil    DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, status, dueAt])
  @@index([clientId, touchType])
  @@index([organizationId, touchType, status])
}

model CheckInTemplate {
  id              String                 @id @default(cuid())
  organizationId  String
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  touchType       ClientCheckInTouchType
  subject         String
  body            String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, touchType])
}
