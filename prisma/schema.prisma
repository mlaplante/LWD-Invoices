  automation      EmailAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  invoiceId       String
  recipientEmail  String
  sentAt          DateTime        @default(now())
  @@index([automationId])
  @@index([invoiceId])
  @@unique([automationId, invoiceId])
}

// ─── Email Delivery Events (Resend webhook ingestion) ─────────────────────────

model EmailEvent {
  id             String   @id @default(cuid())
  // Resend message id from the original send response and the webhook payload.
  resendId       String
  // Raw event type from Resend, e.g. "email.delivered" / "email.opened" / "email.clicked".
  type           String
  occurredAt     DateTime
  recipient      String
  // Populated only on click events.
  link           String?
  // Resolved from the `org_id` tag on the original send. Optional because we may
  // ingest events for emails sent before tagging was wired in.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  // Resolved from the `invoice_id` tag on the original send. Optional because not
  // every email relates to an invoice (e.g. scheduled reports) and legacy sends
  // predate the tag. Powers the per-invoice engagement timeline and the
  // "viewed but unpaid" reminder trigger.
  invoiceId      String?
  invoice        Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([resendId])
  @@index([organizationId, type, occurredAt])
  @@index([invoiceId, occurredAt])
}

// A client reply captured by the inbound-email webhook. Outbound invoice emails
// carry a Reply-To of reply+<invoiceId>@<inbound-domain>; when the client
// replies, the webhook resolves the invoice from that address, records the
// message here, and threads it onto a support ticket so the conversation is
// captured in one place.
model InboundEmail {
  id         String   @id @default(cuid())
  fromEmail  String
  subject    String?
  bodyText   String?
  // Provider message id + In-Reply-To header, for de-duplication and threading.
  messageId  String?
  inReplyTo  String?
  receivedAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceId      String?
  invoice        Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  ticketId       String?
  ticket         Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId, receivedAt])
  @@index([invoiceId])
  @@index([messageId])
}

// ─── Scheduled Reports ───────────────────────────────────────────────────────

model ScheduledReport {
  id              String          @id @default(cuid())
  reportType      ReportType
  frequency       ReportFrequency
  dayOfWeek       Int?            // 0=Sunday...6=Saturday (for WEEKLY)
  dayOfMonth      Int?            // 1-28 (for MONTHLY/QUARTERLY)
  recipients      String[]        // email addresses
  enabled         Boolean         @default(true)
  lastSentAt      DateTime?

  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
  @@index([enabled])
}

// ─── Reminder Sequences ──────────────────────────────────────────────────────

model ReminderSequence {
  id              String   @id @default(cuid())
  name            String
  isDefault       Boolean  @default(false)
  enabled         Boolean  @default(true)

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  steps           ReminderStep[]
  invoices        Invoice[]

  createdAt       DateTime @default(now())

  @@index([organizationId])
}

model ReminderStep {
  id                  String   @id @default(cuid())
  // How this step is scheduled. DUE_DATE_OFFSET uses daysRelativeToDue; VIEWED_UNPAID
  // fires once the invoice email has been opened and remains unpaid (see viewedDelayHours).
  trigger             ReminderStepTrigger @default(DUE_DATE_OFFSET)
  daysRelativeToDue   Int      // negative = before due, 0 = on due, positive = after due (DUE_DATE_OFFSET only)
  // For VIEWED_UNPAID steps: hours to wait after the first open before nudging.
  viewedDelayHours    Int?
  subject             String
  body                String
  sort                Int      @default(0)

  sequenceId          String
  sequence            ReminderSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  logs                ReminderLog[]

  createdAt           DateTime @default(now())

  @@index([sequenceId])
}

model ReminderLog {
  id         String   @id @default(cuid())
  sentAt     DateTime @default(now())

  stepId     String
  step       ReminderStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  invoiceId  String
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([stepId, invoiceId])   // prevents double-sends
  @@index([invoiceId])
}

// An ad-hoc reminder sent outside the automated sequences (e.g. the one-click
// "Send reminder" in Smart Collections). Unlike ReminderLog it isn't tied to a
// sequence step, so it lives here. Feeds the collections risk model's
// remindersSent / last-reminded signals so the dunning queue reflects manual
// follow-ups.
model InvoiceReminder {
  id             String   @id @default(cuid())
  sentAt         DateTime @default(now())
  subject        String
  tone           String?  // helpful | professional | firm
  source         String?  // ai | template_fallback
  channel        String   @default("email")

  invoiceId      String
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([invoiceId, sentAt])
  @@index([organizationId, sentAt])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entityType  String
  entityId    String
  entityLabel String?
  diff        Json?
  userId      String?
  userLabel   String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model SignatureAuditLog {
  id              String   @id @default(cuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId  String
  signedByName    String
  signedByEmail   String
  signedByIp      String
  userAgent       String?
  documentHash    String   // SHA-256 hash of proposal content at time of signing
  signatureHash   String   // SHA-256 hash of signature data

  createdAt       DateTime @default(now())

  @@index([invoiceId])
  @@index([organizationId])
}

// ─── Support Tickets ──────────────────────────────────────────────────────────

model Ticket {
  id       String         @id @default(cuid())
  number   Int
  subject  String
  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(NORMAL)

  clientId     String?
  client       Client?         @relation(fields: [clientId], references: [id])
  assignedToId String?
  messages     TicketMessage[]
  inboundEmails InboundEmail[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, number])
}

model TicketMessage {
  id         String  @id @default(cuid())
  body       String
  isStaff    Boolean @default(true)
  authorId   String?
  authorName String?

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Project Discussions ──────────────────────────────────────────────────────

model Discussion {
  id         String  @id @default(cuid())
  subject    String
  body       String
  isStaff    Boolean @default(true)
  authorId   String?
  authorName String?

  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  replies        DiscussionReply[]

  createdAt DateTime @default(now())
}

model DiscussionReply {
  id         String  @id @default(cuid())
  body       String
  isStaff    Boolean @default(true)
  authorId   String?
  authorName String?

  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Proposal Templates ──────────────────────────────────────────────────────

model ProposalTemplate {
  id              String   @id @default(cuid())
  name            String
  sections        Json     // Array of { key, title, content } objects
  isDefault       Boolean  @default(false)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  proposals       ProposalContent[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProposalContent {
  id              String   @id @default(cuid())
  invoiceId       String   @unique
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId      String?
  template        ProposalTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sections        Json     // Array of { key, title, content } objects
  fileUrl         String?  // Supabase Storage path for uploaded proposal file
  fileName        String?  // Original filename (e.g., "proposal-v2.pdf")
  version         String   @default("1.0")
  // Set when the "viewed but not signed" nudge fires, so the cron only sends one
  // nudge per proposal (mirrors ReminderLog's double-send guard for invoices).
  nudgeSentAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Late Fee Entries ─────────────────────────────────────────────────────────

model LateFeeEntry {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(20, 10)
  feeType   String
  feeRate   Decimal  @db.Decimal(10, 4)
  isWaived  Boolean  @default(false)
  waivedAt  DateTime?
  waivedBy  String?
  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─── Retainers / Deposits ────────────────────────────────────────────────────

model Retainer {
  id             String   @id @default(cuid())
  balance        Decimal  @default(0) @db.Decimal(20, 10)
  clientId       String   @unique
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions   RetainerTransaction[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clientId, organizationId])
}

model RetainerTransaction {
  id          String   @id @default(cuid())
  type        String   // "deposit" | "drawdown" | "refund"
  amount      Decimal  @db.Decimal(20, 10)
  description String?
  method      String?
  retainerId  String
  retainer    Retainer @relation(fields: [retainerId], references: [id], onDelete: Cascade)
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

enum HoursRetainerResetInterval {
  MONTHLY
}

enum HoursRetainerPeriodStatus {
  ACTIVE
  CLOSED
}

model HoursRetainer {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name           String
  includedHours  Decimal  @db.Decimal(16, 8)
  resetInterval  HoursRetainerResetInterval?
  hourlyRate     Decimal? @db.Decimal(20, 10)
  active         Boolean  @default(true)

  periods        HoursRetainerPeriod[]
  timeEntries    TimeEntry[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, clientId])
}

model HoursRetainerPeriod {
  id                    String   @id @default(cuid())
  retainerId            String
  retainer              HoursRetainer @relation(fields: [retainerId], references: [id], onDelete: Cascade)

  label                 String
  periodStart           DateTime
  periodEnd             DateTime
  includedHoursSnapshot Decimal  @db.Decimal(16, 8)
  status                HoursRetainerPeriodStatus @default(ACTIVE)

  timeEntries           TimeEntry[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([retainerId, status])
}

// ─── Client Retention / Check-In Automation ───────────────────────────────────
// Surfaces a weekly admin-reviewed queue of relationship touches (thank-you,
// 30-day check-in, quarterly, annual). The system only queues the reminder —
// the admin writes the actual message — so the relationship still feels human.

model ClientCheckIn {
  id              String                 @id @default(cuid())
  organizationId  String
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Optional project anchor — PROJECT_CLOSE / THIRTY_DAY / ANNUAL touches are
  // tied to a specific project; QUARTERLY is a client-level rhythm.
  projectId       String?
  project         Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)

  touchType       ClientCheckInTouchType
  status          ClientCheckInStatus    @default(PENDING)
  dueAt           DateTime
  outcome         ClientCheckInOutcome?
  notes           String?
  completedAt     DateTime?
  dismissedAt     DateTime?
  snoozedUntil    DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, status, dueAt])
  @@index([clientId, touchType])
  @@index([organizationId, touchType, status])
}

model CheckInTemplate {
  id              String                 @id @default(cuid())
  organizationId  String
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  touchType       ClientCheckInTouchType
  subject         String
  body            String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, touchType])
}

// ─── Disputes / Chargebacks ─────────────────────────────────────────────────────
// A Stripe dispute (chargeback) against a recorded payment. Mirrored from
// charge.dispute.* webhook events and updated as the dispute progresses.
// Evidence is submitted back to Stripe via the disputes router; we never
// auto-mutate the source invoice (a dispute can be won and re-charged).

enum DisputeStatus {
  NEEDS_RESPONSE          // Stripe: needs_response / warning_needs_response
  UNDER_REVIEW            // Stripe: under_review / warning_under_review
  WON                     // Stripe: won
  LOST                    // Stripe: lost
  WARNING_CLOSED          // Stripe: warning_closed (early-warning resolved)
  CHARGE_REFUNDED         // Stripe: charge_refunded (resolved by refund)
  CLOSED                  // Stripe: any other terminal state
}

model Dispute {
  id              String        @id @default(cuid())
  stripeDisputeId String        @unique
  stripeChargeId  String?
  paymentIntentId String?
  amount          Decimal       @db.Decimal(20, 2)
  currency        String
  reason          String?       // Stripe dispute reason (fraudulent, product_not_received, ...)
  status          DisputeStatus @default(NEEDS_RESPONSE)
  // Raw Stripe status string, kept verbatim for display + forward-compat with
  // statuses we don't normalize into the enum.
  stripeStatus    String
  evidenceDueBy   DateTime?
  evidenceSubmittedAt DateTime?
  // Whether the underlying charge is still refundable (Stripe's is_charge_refundable).
  isRefundable    Boolean       @default(true)
  // Free-form internal working notes (not sent to Stripe).
  internalNotes   String?

  paymentId       String?
  payment         Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  invoiceId       String?
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([invoiceId])
}

// ─── Refunds ────────────────────────────────────────────────────────────────────
// First-class refund record tied to a Payment + Invoice. Stripe refunds are
// issued via the refunds router (stripe.refunds.create) and reconciled by the
// charge.refunded webhook; manual refunds record an off-platform return.

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

model Refund {
  id              String       @id @default(cuid())
  stripeRefundId  String?      @unique
  amount          Decimal      @db.Decimal(20, 2)
  currency        String
  // Stripe refund reason: duplicate | fraudulent | requested_by_customer, or null.
  reason          String?
  status          RefundStatus @default(PENDING)
  method          String       @default("stripe") // stripe | manual
  notes           String?
  // When the refund should also produce a credit note, the issued credit-note
  // invoice id is recorded here (credit notes are modeled as Invoice rows).
  creditNoteId    String?
  createdByUserId String?

  paymentId       String
  payment         Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId       String
  invoice         Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, createdAt])
  @@index([invoiceId])
  @@index([paymentId])
}

// ─── No-code Automation Builder ───────────────────────────────────────────────
// Generalizes the fixed EmailAutomation + ReminderSequence features into
// composable trigger → conditions → actions rules. A rule fires on an invoice
// lifecycle event (or the daily overdue sweep), checks its conditions against
// the invoice, and runs its ordered actions. AutomationRun records each
// (rule, invoice) execution once, mirroring EmailAutomationLog's double-send
// guard.

enum AutomationTrigger {
  PAYMENT_RECEIVED
  INVOICE_SENT
  INVOICE_VIEWED
  INVOICE_OVERDUE
}

enum AutomationConditionField {
  TOTAL
  AMOUNT_DUE
  DAYS_OVERDUE
  STATUS
  CLIENT_NAME
  CURRENCY_CODE
}

enum AutomationOperator {
  EQ
  NEQ
  GT
  GTE
  LT
  LTE
  CONTAINS
  NOT_CONTAINS
}

enum AutomationConditionLogic {
  AND
  OR
}

enum AutomationActionType {
  SEND_EMAIL
  NOTIFY_ADMINS
}

model AutomationRule {
  id             String                   @id @default(cuid())
  name           String
  trigger        AutomationTrigger
  // How the conditions combine. With no conditions, the rule fires on every
  // event of its trigger type.
  conditionLogic AutomationConditionLogic @default(AND)
  enabled        Boolean                  @default(true)

  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  conditions     AutomationCondition[]
  actions        AutomationAction[]
  runs           AutomationRun[]

  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([organizationId, trigger, enabled])
}

model AutomationCondition {
  id       String                   @id @default(cuid())
  field    AutomationConditionField
  operator AutomationOperator
  // Comparison value as text; the engine coerces to a number for numeric fields.
  value    String
  sort     Int                      @default(0)

  ruleId   String
  rule     AutomationRule           @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model AutomationAction {
  id     String               @id @default(cuid())
  type   AutomationActionType
  // Type-specific payload, e.g. { subject, body } for SEND_EMAIL or
  // { title, body } for NOTIFY_ADMINS. Templates support {{ variable }} tokens.
  config Json
  sort   Int                  @default(0)

  ruleId String
  rule   AutomationRule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model AutomationRun {
  id         String         @id @default(cuid())
  // executed | failed | partial — set by the runner after attempting actions.
  status     String         @default("executed")
  actionsRun Int            @default(0)
  detail     String?

  ruleId     String
  rule       AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  invoiceId  String
  invoice    Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt  DateTime       @default(now())

  @@unique([ruleId, invoiceId]) // fire each rule at most once per invoice
  @@index([ruleId, createdAt])
  @@index([invoiceId])
}

// ─── Month-end close ──────────────────────────────────────────────────────────
// A period-close record per (org, year, month). The month-end-close agent
// reconciles the period, flags anomalies, and drafts adjusting entries; closing
// freezes the full report into `snapshot` and locks the period (advisory). A
// closed period can be reopened (status REOPENED, snapshot preserved) and later
// re-closed with a fresh snapshot. A period is "locked" iff a row exists with
// status CLOSED.

enum PeriodCloseStatus {
  CLOSED
  REOPENED
}

model PeriodClose {
  id          String            @id @default(cuid())
  periodYear  Int
  periodMonth Int               // 1-12
  status      PeriodCloseStatus @default(CLOSED)

  // Headline totals, denormalized for fast listing without parsing the snapshot.
  invoiced  Decimal @default(0) @db.Decimal(20, 2)
  collected Decimal @default(0) @db.Decimal(20, 2)
  refunded  Decimal @default(0) @db.Decimal(20, 2)
  expenses  Decimal @default(0) @db.Decimal(20, 2)
  netCash   Decimal @default(0) @db.Decimal(20, 2)

  errorCount      Int @default(0)
  warningCount    Int @default(0)
  adjustmentCount Int @default(0)

  // The full MonthEndCloseReport at close time (reconciliation + anomalies +
  // drafted adjusting entries + the AI/deterministic narrative).
  snapshot Json

  notes          String?
  closedByUserId String?
  closedByLabel  String?
  closedAt       DateTime  @default(now())
  reopenedByUserId String?
  reopenedAt       DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, periodYear, periodMonth])
  @@index([organizationId, periodYear, periodMonth])
}

// ─── Dashboard Customization ───────────────────────────────────────────────────
// Per-user, per-org widget layout preference. Stores an ordered JSON array of
// { key, visible } entries. Bare `userId String` (no local User FK) matches the
// Timer/TimeEntry pattern for Supabase auth users.

model UserDashboardPreference {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  layoutJson     String       // JSON: ordered array of { key: string, visible: boolean }
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ─── Webhook Delivery Dedup ────────────────────────────────────────────────────
// Cross-instance idempotency ledger for inbound webhooks (Stripe, Resend).
// One row per (provider, externalId); the unique constraint makes "already
// processed?" a single atomic insert, so multi-replica deploys can't
// double-process a retried delivery. Rows are pruned opportunistically after
// PRUNE_AFTER_MS in src/server/services/webhook-dedup.ts — providers stop
// retrying long before that window closes.

model WebhookDelivery {
  id          String   @id @default(cuid())
  provider    String
  externalId  String
  processedAt DateTime @default(now())

  @@unique([provider, externalId])
  @@index([processedAt])
}
