  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum EmailAutomationTrigger {
  PAYMENT_RECEIVED
  INVOICE_SENT
  INVOICE_VIEWED
  INVOICE_OVERDUE
}

enum ReminderStepTrigger {
  DUE_DATE_OFFSET
  VIEWED_UNPAID
}

enum ReportType {
  PROFIT_LOSS
  AGING
  UNPAID
  EXPENSES
  TAX_LIABILITY
}

enum ReportFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum PaymentAttemptStatus {
  PENDING
  SUCCEEDED
  FAILED
}

// ─── 1099 / Contractor Tax Pack ───────────────────────────────────────────────

// W-9 collection lifecycle for a contractor (payee).
enum W9Status {
  NOT_REQUESTED
  REQUESTED
  RECEIVED
}

// Taxpayer Identification Number type from the contractor's W-9.
enum ContractorTinType {
  SSN
  EIN
}

// How a contractor payment was made. CARD and THIRD_PARTY (PayPal/Venmo/etc.)
// are reported to the IRS by the payment processor on a 1099-K, so they are
// excluded from the payer's 1099-NEC box 1 total by default.
enum ContractorPaymentMethod {
  CHECK
  ACH
  WIRE
  CASH
  CARD
  THIRD_PARTY
  OTHER
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model Organization {
  id                String   @id
  name              String
  slug              String?  @unique
  logoUrl           String?
  brandColor        String?  @default("#2563eb")
  invoicePrefix     String   @default("INV")
  invoiceNextNumber Int      @default(1)
  // IANA time zone used to bucket local send/open analytics and other
  // org-local scheduled features. Defaults to UTC for existing organizations.
  timeZone          String   @default("UTC")
  creditNotePrefix     String   @default("CN")
  creditNoteNextNumber Int      @default(1)
  taskTimeInterval        Float    @default(0)
  defaultPaymentTermsDays Int      @default(30)
  paymentReminderDays     Int[]    @default([1, 3])
  defaultDepositPercent   Int?
  smartRemindersEnabled   Boolean  @default(false)
  smartRemindersThreshold Int      @default(80)
  // When true, invoice tax is computed via Stripe Tax Calculation API using
  // the org's Stripe gateway secret + the client's destination address. When
  // false (default), the legacy compound-tax calculator in src/server/services/
  // tax-calculator.ts owns tax computation. Switching to true requires the
  // org to have a Stripe gateway configured AND a complete origin address.
  stripeTaxEnabled        Boolean  @default(false)
  emailBccOwner           Boolean  @default(true)
  lateFeeEnabled          Boolean @default(false)
  lateFeeType             String?
  lateFeeAmount           Decimal @default(0) @db.Decimal(10, 4)
  lateFeeGraceDays        Int     @default(0)
  lateFeeRecurring        Boolean @default(false)
  lateFeeMaxApplications  Int?
  lateFeeIntervalDays     Int     @default(30)
  // ─── Dunning (failed-payment recovery) ──────────────────────────────────────
  // When enabled, the dunning-retries cron re-attempts failed auto-charges on
  // a 1/3/7-day schedule, then escalates to a client email + admin alert.
  dunningEnabled          Boolean @default(false)
  // ─── Early-payment discount (e.g. 2/10 net 30) ──────────────────────────────
  // When enabled, new SIMPLE/DETAILED invoices snapshot percent+days at
  // creation; clients paying the full balance within `days` of the invoice
  // date get `percent` off (applied post-tax at redemption time).
  earlyPayDiscountEnabled Boolean @default(false)
  earlyPayDiscountPercent Decimal @default(0) @db.Decimal(5, 2)
  earlyPayDiscountDays    Int     @default(10)
  // ─── Two-Factor Authentication ──────────────────────────────────────────────
  require2FA              Boolean @default(false)
  // ─── Portal Branding ────────────────────────────────────────────────────────
  portalTagline       String?
  portalFooterText    String?
  brandFont           String?  // "inter" | "georgia" | "system"
  hidePoweredBy       Boolean  @default(false)
  // ─── Invoice Templates ──────────────────────────────────────────────────────
  invoiceTemplate      String   @default("modern")  // "modern" | "classic" | "minimal" | "compact"
  invoiceFontFamily    String?  // "helvetica" | "georgia" | "courier"
  invoiceAccentColor   String?  // hex color, falls back to brandColor
  invoiceShowLogo      Boolean  @default(true)
  invoiceFooterText    String?
  // ─── Organization Address ───────────────────────────────────────────────────
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  postalCode          String?
  country             String?
  phone               String?
  // ─── 1099 / Contractor Tax Pack ─────────────────────────────────────────────
  // Payer's federal Tax ID (EIN/SSN), printed in the PAYER block of generated
  // 1099-NEC forms. Stored as entered; surfaced only to org admins.
  payerTin            String?
  // ─── Mileage Tracking ───────────────────────────────────────────────────────
  // Default deduction/reimbursement rate per mile. Snapshotted onto each
  // MileageEntry at creation so changing the rate doesn't rewrite history.
  // Default mirrors the 2025 IRS standard business rate ($0.70/mile).
  mileageRatePerMile  Decimal  @default(0.70) @db.Decimal(10, 4)
  // ─── Estimated Quarterly Taxes (self-employment set-aside) ──────────────────
  // US calendar-year, cash-basis estimator. Recommends a reserve of
  // estimatedTaxSetAsidePercent × net SE income (gross payments received −
  // deductible expenses − mileage deduction). When enabled, the
  // estimated-tax-reminders cron emails org admins estimatedTaxReminderDays
  // before each federal due date (Apr 15 / Jun 15 / Sep 15 / Jan 15).
  estimatedTaxEnabled            Boolean   @default(false)
  estimatedTaxSetAsidePercent    Decimal   @default(30) @db.Decimal(5, 2)
  estimatedTaxReminderDays       Int       @default(7)
  estimatedTaxReminderLastSentAt DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  members           UserOrganization[]
  invitations       Invitation[]
  clients           Client[]
  currencies        Currency[]
  taxes             Tax[]
  items             Item[]
  invoices          Invoice[]
  partialPayments   PartialPayment[]
  payments          Payment[]
  paymentAttempts   PaymentAttempt[]
  gateways          GatewaySetting[]
  comments          Comment[]
  projects          Project[]
  milestones        Milestone[]
  tasks             ProjectTask[]
  taskStatuses      TaskStatus[]
  projectTemplates  ProjectTemplate[]
  timeEntries       TimeEntry[]
  timers            Timer[]
  expenses                Expense[]
  expenseCategories       ExpenseCategory[]
  expenseSuppliers        ExpenseSupplier[]
  expenseBudgets          ExpenseBudget[]
  recurringExpenses       RecurringExpense[]
  mileageEntries          MileageEntry[]
  contractors             Contractor[]
  contractorPayments      ContractorPayment[]
  recurringInvoices       RecurringInvoice[]
  creditNoteApplications  CreditNoteApplication[]
  attachments             Attachment[]
  notifications           Notification[]
  auditLogs               AuditLog[]
  tickets                 Ticket[]
  discussions             Discussion[]
  proposalTemplates       ProposalTemplate[]
  proposalContents        ProposalContent[]
  emailAutomations        EmailAutomation[]
  scheduledReports        ScheduledReport[]
  lateFeeEntries          LateFeeEntry[]
  retainers               Retainer[]
  hoursRetainers          HoursRetainer[]
  reminderSequences       ReminderSequence[]
  automationRules         AutomationRule[]
  savedPaymentMethods     SavedPaymentMethod[]
  emailEvents             EmailEvent[]
  inboundEmails           InboundEmail[]
  invoiceReminders        InvoiceReminder[]
  clientCheckIns          ClientCheckIn[]
  checkInTemplates        CheckInTemplate[]
  // Retention/check-in automation feature flag. retentionEnabledAt is the
  // floor for cron-generated check-ins so newly-enabled orgs don't get
  // flooded with historical backfill.
  retentionEnabled        Boolean   @default(false)
  retentionEnabledAt      DateTime?
  // ─── Proposal "viewed but not signed" nudge ─────────────────────────────────
  // When enabled, the proposal-nudge cron emails the client once a sent proposal
  // has been opened but remains unsigned after proposalNudgeDelayHours.
  proposalNudgeEnabled    Boolean   @default(true)
  proposalNudgeDelayHours Int       @default(48)
  // ─── Weekly AI Business Briefing ────────────────────────────────────────────
  // Proactive Monday email composing overdue total, at-risk clients, and the
  // projected cash position from the analytics cores. When recipients is empty
  // the briefing cron falls back to the org's admin/owner email addresses.
  weeklyBriefingEnabled    Boolean   @default(false)
  weeklyBriefingRecipients String[]  @default([])
  weeklyBriefingLastSentAt DateTime?

  disputes          Dispute[]
  refunds           Refund[]
  periodCloses      PeriodClose[]
  dashboardPreferences UserDashboardPreference[]
  clientEmailPreferences ClientEmailPreference[]
  forecastSnapshots ForecastSnapshot[]
}

// Weekly capture of the cash-flow forecast so it can be graded against what
// actually happened. The snapshot cron writes one row per horizon (30/60/90)
// per org; once `matureAt` passes, the same cron fills `actualInflow` (sum of
// payments received in the window) and stamps `scoredAt`. Inflow is the graded
// axis — outflows are deterministic schedules and kept only as context.
model ForecastSnapshot {
  id               String   @id @default(cuid())
  capturedAt       DateTime @default(now())
  horizonDays      Int
  // capturedAt + horizonDays, denormalized so the scoring pass is one indexed query.
  matureAt         DateTime
  projectedInflow  Decimal  @db.Decimal(20, 2)
  projectedOutflow Decimal  @db.Decimal(20, 2)
  // Blended collection probability (0-1) the forecast carried at capture time.
  confidence       Decimal  @db.Decimal(5, 4)
  actualInflow     Decimal? @db.Decimal(20, 2)
  scoredAt         DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId, capturedAt])
  @@index([scoredAt, matureAt])
}

model User {
  id          String   @id @default(cuid())
  clerkId     String?  @unique
  supabaseId  String?  @unique
  email       String   @unique
  firstName   String?
  lastName    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invitationsSent Invitation[] @relation("InvitedBy")
  memberships     UserOrganization[]
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           UserRole     @default(ADMIN)
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Invitation {
  id        String           @id @default(cuid())
  email     String
  role      UserRole         @default(VIEWER)
  // Bearer secret: random uuid(4) default, overridden with generateSecureToken() in app code
  token     String           @unique @default(uuid(4))
  expiresAt DateTime
  status    InvitationStatus @default(PENDING)

  invitedById    String
  invitedBy      User         @relation("InvitedBy", fields: [invitedById], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([email, organizationId])
}

model Client {
  id               String   @id @default(cuid())
  name             String
  email            String?
  // Additional recipients copied on invoice + receipt emails. Persisted per
  // client so the typical "always CC the accountant" case is one-time setup.
  // Send dialogs can override on a per-send basis without mutating this list.
  ccEmails         String[] @default([])
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  country          String?
  taxId            String?
  // When true, invoice tax computation skips this client. The invoice
  // tax-resolver checks the flag before applying any rate (legacy or
  // Stripe Tax) and renders a 0 taxTotal with a "Tax exempt" line.
  isTaxExempt      Boolean  @default(false)
  notes                   String?
  // Free-form labels for segmentation ("retainer", "net-60", "agency", ...).
  // Normalized on write (trimmed, deduped case-insensitively, ≤20 per client)
  // by normalizeTags() in client-csv.ts. Filterable on the clients list.
  tags                    String[] @default([])
  defaultPaymentTermsDays Int?
  portalToken             String   @unique @default(uuid(4))
  // Bearer token for the public email-preferences page (/unsubscribe/[token]).
  // Deliberately separate from portalToken so unsubscribe links in every
  // marketing-adjacent email footer never grant portal/document access.
  emailPreferencesToken   String   @unique @default(uuid(4))
  portalPassphraseHash String?
  // ── Self-service "forgot passphrase" reset ──
  // SHA-256 of the emailed reset token (plaintext is never stored) and its
  // expiry. Cleared on successful reset; a new request overwrites both.
  portalPassphraseResetTokenHash String?   @unique
  portalPassphraseResetExpiresAt DateTime?
  stripeCustomerId   String?
  autoChargeEnabled  Boolean @default(false)
  creditBalance    Decimal @default(0)
  // ─── Credit limit / credit hold ─────────────────────────────────────────────
  // creditLimit caps the open AR (sum of unpaid invoice balances) you're willing
  // to carry for this client; null means no limit. When on creditHold, the UI
  // surfaces a prominent warning before sending invoices or charging cards — it
  // is advisory (warn-only), not a hard block.
  creditLimit            Decimal?  @db.Decimal(20, 2)
  creditHold             Boolean   @default(false)
  creditHoldReason       String?
  creditHoldSetAt        DateTime?
  // True when the current hold was placed automatically by the health-score
  // trigger (vs. set by an admin). Auto-holds are released automatically when
  // the score recovers; manual holds are only released by an admin.
  creditHoldAuto         Boolean   @default(false)
  // Policy: auto-place a credit hold when this client's health score drops below
  // autoCreditHoldThreshold. Connects the client-health-score core to collections.
  autoCreditHoldEnabled  Boolean   @default(false)
  autoCreditHoldThreshold Int?
  isArchived       Boolean  @default(false)
  // Email deliverability — populated by the Resend webhook handler when
  // a client's address bounces (hard) or marks an email as spam. Used to
  // suppress further sends and surface the issue in the client UI.
  emailBouncedAt    DateTime?
  emailComplainedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices              Invoice[]
  projects              Project[]
  tickets               Ticket[]
  portalSessions        ClientPortalSession[]
  retainer              Retainer?
  hoursRetainers        HoursRetainer[]
  savedPaymentMethods   SavedPaymentMethod[]
  checkIns              ClientCheckIn[]
  inboundEmails         InboundEmail[]
  disputes              Dispute[]
  emailPreferences      ClientEmailPreference[]
}

// Per-client opt-out for non-transactional email kinds (CAN-SPAM / GDPR).
// Absence of a row means the kind is enabled; rows are upserted when the
// client (via the public unsubscribe page) or an admin toggles a kind.
// Transactional email — invoice sends, receipts, dunning for failed
// charges — is not governed by this table and is always delivered.
model ClientEmailPreference {
  id      String              @id @default(cuid())
  kind    EmailPreferenceKind
  enabled Boolean             @default(true)

  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, kind])
  @@index([organizationId])
}

enum EmailPreferenceKind {
  PAYMENT_REMINDERS
  PROPOSAL_NUDGES
  AUTOMATIONS
}

model ClientPortalSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  userAgent String?
  ipAddress String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([token])
  @@index([clientId])
  @@index([expiresAt])
}

model Currency {
  id             String   @id @default(cuid())
  code           String
  name           String
  symbol         String
  symbolPosition String   @default("before")
  exchangeRate   Decimal  @default(1) @db.Decimal(18, 6)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  projects       Project[]

  @@unique([organizationId, code])
}

model Tax {
  id         String   @id @default(cuid())
  name       String
  rate       Decimal  @db.Decimal(8, 4)
  isCompound Boolean  @default(false)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organizationId   String
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceLineTaxes InvoiceLineTax[]
  expenses              Expense[]
  recurringExpenses     RecurringExpense[] @relation("RecurringExpenseTax")
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  rate        Decimal? @db.Decimal(18, 6)
  unit        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── Invoice Models ───────────────────────────────────────────────────────────

model Invoice {
  id         String        @id @default(cuid())
  number     String
  type       InvoiceType   @default(DETAILED)
  status     InvoiceStatus @default(DRAFT)
  date       DateTime      @default(now())
  dueDate    DateTime?
  lastSent   DateTime?
  lastViewed DateTime?

  // ─── Scheduled sending ───────────────────────────────────────────────────
  // When set, the scheduled-invoice-sends cron emails this invoice at (or
  // shortly after) this instant and clears the field. Typically derived from
  // the client's best-send-window recommendation, but any future time works.
  // scheduledSendCc snapshots the per-send CC override chosen at scheduling
  // time (empty array = fall back to client.ccEmails at send time).
  scheduledSendAt DateTime?
  scheduledSendCc String[]  @default([])

  // Set when dunning has exhausted charge retries (or hit a non-retryable
  // failure) and emailed the client to pay manually. Terminal per invoice:
  // the dunning cron skips invoices with this set.
  dunningEscalatedAt DateTime?

  // Cached totals (recalculated on every save)
  subtotal      Decimal @default(0) @db.Decimal(20, 10)
  discountTotal Decimal @default(0) @db.Decimal(20, 10)
  taxTotal      Decimal @default(0) @db.Decimal(20, 10)
  total         Decimal @default(0) @db.Decimal(20, 10)

  // Currency
  currencyId   String
  currency     Currency @relation(fields: [currencyId], references: [id])
  exchangeRate Decimal  @default(1) @db.Decimal(10, 5)

  // Invoice-level discount
  discountType        String?  // "percentage" | "fixed" | null
  discountAmount      Decimal  @default(0) @db.Decimal(20, 10)
  discountDescription String?

  // SIMPLE type only
  simpleAmount Decimal? @db.Decimal(20, 10)

  retainerApplied Decimal @default(0) @db.Decimal(20, 10)
  creditApplied   Decimal @default(0) @db.Decimal(20, 10)

  // ─── Early-payment discount ────────────────────────────────────────────────
  // Offer snapshot taken from the org at creation (null = no offer). On
  // redemption the discount is applied post-tax — a FIXED_DISCOUNT line is
  // appended and cached totals adjusted — and redeemedAt/amount record it.
  earlyPayDiscountPercent    Decimal?  @db.Decimal(5, 2)
  earlyPayDiscountDays       Int?
  earlyPayDiscountRedeemedAt DateTime?
  earlyPayDiscountAmount     Decimal   @default(0) @db.Decimal(20, 10)

  // When tax was computed by Stripe Tax (Organization.stripeTaxEnabled), this
  // holds the Calculation ID returned by Stripe. Used later when reconciling
  // the calculation into a Stripe Tax Transaction at finalization. Null when
  // the legacy tax-calculator was used.
  stripeTaxCalculationId String?
  // Set when the Stripe Tax Calculation has been promoted to a Tax Transaction
  // — typically at payment finalization. Persisting it lets us issue reversals
  // later when a credit note is generated against this invoice.
  stripeTaxTransactionId String?

  // Credit note fields
  sourceInvoiceId  String?
  creditNoteStatus String?  // DRAFT | ISSUED | APPLIED | VOIDED

  notes                String?
  isArchived           Boolean @default(false)
  reminderDaysOverride Int[]   @default([])

  // Optional per-invoice reminder sequence override
  reminderSequenceId  String?
  reminderSequence    ReminderSequence? @relation(fields: [reminderSequenceId], references: [id], onDelete: SetNull)

  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  isChangeOrder  Boolean      @default(false)

  portalToken String @unique @default(uuid(4))

  // E-signature fields (for proposals/estimates)
  signedAt       DateTime?
  signedByName   String?
  signedByEmail  String?
  signedByIp     String?
  signatureData  String?   // Encrypted base64 PNG or SVG path data

  lines           InvoiceLine[]
  partialPayments PartialPayment[]
  payments          Payment[]
  paymentAttempts  PaymentAttempt[]
  comments        Comment[]
  recurringInvoice        RecurringInvoice?
  creditNotesIssued       CreditNoteApplication[] @relation("CreditNoteSource")
  creditNotesReceived     CreditNoteApplication[] @relation("CreditNoteTarget")
  proposalContent         ProposalContent?
  signatureAuditLogs      SignatureAuditLog[]
  lateFeeEntries          LateFeeEntry[]
  retainerTransactions    RetainerTransaction[]
  reminderLogs            ReminderLog[]
  manualReminders         InvoiceReminder[]
  automationRuns          AutomationRun[]
  emailEvents             EmailEvent[]
  inboundEmails           InboundEmail[]
  milestone               Milestone?
  disputes                Dispute[]
  refunds                 Refund[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([organizationId, isArchived])
  @@index([organizationId, dueDate])
  @@index([organizationId, projectId])
  @@index([scheduledSendAt])
}

model InvoiceLine {
  id                   String   @id @default(cuid())
  sort                 Int      @default(0)
  lineType             LineType @default(STANDARD)
  name                 String
  description          String?
  qty                  Decimal  @default(1) @db.Decimal(10, 4)
  rate                 Decimal  @default(0) @db.Decimal(20, 10)
  period               Decimal? @db.Decimal(10, 2)
  discount             Decimal  @default(0) @db.Decimal(20, 10)
  discountIsPercentage Boolean  @default(false)

  // Cached calculated values (recomputed on save)
  subtotal Decimal @default(0) @db.Decimal(20, 10)
  taxTotal Decimal @default(0) @db.Decimal(20, 10)
  total    Decimal @default(0) @db.Decimal(20, 10)

  // Source tracking (time entries, expenses, etc.)
  sourceTable String?
  sourceId    String?

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  taxes              InvoiceLineTax[]
  stripeTaxBreakdown InvoiceLineStripeTaxBreakdown[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-line, per-jurisdiction tax row populated only when Stripe Tax computed
// the invoice. Coexists with InvoiceLineTax: the legacy path writes
// InvoiceLineTax rows; Stripe Tax writes InvoiceLineStripeTaxBreakdown rows.
// A given line uses one path or the other, never both — switch via
// Organization.stripeTaxEnabled at calc time.
model InvoiceLineStripeTaxBreakdown {
  id                   String      @id @default(cuid())
  invoiceLineId        String
  invoiceLine          InvoiceLine @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)
  // Display info copied from Stripe so we can render without a re-fetch.
  jurisdictionDisplay  String      // e.g. "California" or "Germany"
  jurisdictionLevel    String      // country | state | county | city | district
  // Calculated amounts at the time of computation, in invoice currency.
  amount               Decimal     @db.Decimal(20, 4)
  taxableAmount        Decimal     @db.Decimal(20, 4)
  // Percentage_decimal as returned by Stripe (e.g. "8.25").
  rateDecimal          Decimal     @db.Decimal(8, 4)
  // sales_tax | vat | gst | etc. Free-form for forward compat.
  taxType              String
  // Stripe-provided reason like "standard_rated" / "reverse_charge".
  reason               String?
  createdAt            DateTime    @default(now())

  @@index([invoiceLineId])
}

model InvoiceLineTax {
  id        String  @id @default(cuid())
  taxAmount Decimal @default(0) @db.Decimal(20, 10)

  invoiceLineId String
  invoiceLine   InvoiceLine @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)
  taxId         String
  tax           Tax         @relation(fields: [taxId], references: [id])

  @@unique([invoiceLineId, taxId])
}

model PartialPayment {
  id            String    @id @default(cuid())
  sortOrder     Int       @default(0)
  amount        Decimal   @db.Decimal(20, 10)
  isPercentage  Boolean   @default(false)
  dueDate       DateTime?
  notes         String?
  isPaid        Boolean   @default(false)
  paidAt        DateTime?
  paymentMethod String?
  transactionId String?
  gatewayFee    Decimal   @default(0) @db.Decimal(20, 10)

  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId, isPaid])
}

model Payment {
  id              String   @id @default(cuid())
  amount          Decimal  @db.Decimal(20, 10)
  gatewayFee      Decimal  @default(0) @db.Decimal(20, 10)
  surchargeAmount Decimal  @default(0) @db.Decimal(20, 10)
  method          String
  transactionId   String?
  notes           String?
  paidAt          DateTime @default(now())

  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  disputes       Dispute[]
  refunds        Refund[]

  createdAt DateTime @default(now())

  @@index([organizationId, paidAt])
  @@index([invoiceId])
}

model PaymentAttempt {
  id                   String               @id @default(cuid())
  kind                 String               @default("AUTOPAY")
  status               PaymentAttemptStatus @default(PENDING)
  amount               Decimal              @db.Decimal(20, 10)
  method               String
  processor            String?
  processorId          String?
  processorError       String?
  idempotencyKey       String               @unique
  attemptedAt          DateTime             @default(now())
  completedAt          DateTime?

  invoiceId            String
  invoice              Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId       String
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  savedPaymentMethodId String?
  savedPaymentMethod   SavedPaymentMethod?  @relation(fields: [savedPaymentMethodId], references: [id], onDelete: SetNull)

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([invoiceId, kind])
  @@index([organizationId, status])
  @@index([invoiceId])
}

model SavedPaymentMethod {
  id                    String   @id @default(cuid())
  clientId              String
  organizationId        String
  stripePaymentMethodId String   @unique
  last4                 String
  brand                 String
  expiresMonth          Int
  expiresYear           Int
  isDefault             Boolean  @default(true)
  createdAt             DateTime @default(now())

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paymentAttempts PaymentAttempt[]

  @@unique([clientId, organizationId, stripePaymentMethodId])
  @@index([clientId, organizationId])
}

model GatewaySetting {
  id          String      @id @default(cuid())
  gatewayType GatewayType
  isEnabled   Boolean     @default(false)
  configJson  String
  surcharge   Decimal     @default(0) @db.Decimal(5, 2)
  // Separate surcharge for bank-debit methods (ACH/SEPA) on the Stripe
  // gateway — they cost far less to accept than cards, so orgs typically
  // surcharge them less (or not at all). Only read when gatewayType=STRIPE.
  bankDebitSurcharge Decimal @default(0) @db.Decimal(5, 2)
  label       String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

