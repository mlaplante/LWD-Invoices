  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum GatewayType {
  STRIPE
  PAYPAL
  BANK_TRANSFER
  CASH
  CHECK
  MONEY_ORDER
}

enum InvoiceType {
  SIMPLE
  DETAILED
  ESTIMATE
  CREDIT_NOTE
  DEPOSIT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  ACCEPTED
  REJECTED
}

enum LineType {
  STANDARD
  TIME_ENTRY
  FLAT_RATE
  EXPENSE
  PERCENTAGE_DISCOUNT
  FIXED_DISCOUNT
  PERIOD_DAY
  PERIOD_WEEK
  PERIOD_MONTH
  PERIOD_YEAR
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum AttachmentContext {
  INVOICE
  PROJECT
  CLIENT
  TICKET
}

enum NotificationType {
  INVOICE_SENT
  INVOICE_VIEWED
  INVOICE_PAID
  INVOICE_OVERDUE
  INVOICE_COMMENT
  ESTIMATE_ACCEPTED
  ESTIMATE_REJECTED
  RECURRING_INVOICE_GENERATED
  RECURRING_EXPENSE_GENERATED
  TICKET_CREATED
  TICKET_REPLIED
  RETENTION_QUEUE_READY
  DISPUTE_CREATED
  DISPUTE_UPDATED
  REFUND_ISSUED
  CREDIT_HOLD_PLACED
  AUTOMATION_TRIGGERED
  PROJECT_BUDGET_ALERT
}

enum ClientCheckInTouchType {
  PROJECT_CLOSE
  THIRTY_DAY
  QUARTERLY
  ANNUAL
}

enum ClientCheckInStatus {
  PENDING
  DISMISSED
  COMPLETED
}

enum ClientCheckInOutcome {
  NEW_WORK
  REFERRAL
  NOTHING
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  PAYMENT_RECEIVED
  SENT
  VIEWED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

