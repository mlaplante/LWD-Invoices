generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  STAFF
}

enum GatewayType {
  STRIPE
  PAYPAL
  BANK_TRANSFER
  CASH
  CHECK
  MONEY_ORDER
}

enum InvoiceType {
  SIMPLE
  DETAILED
  ESTIMATE
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  ACCEPTED
  REJECTED
}

enum LineType {
  STANDARD
  TIME_ENTRY
  FLAT_RATE
  EXPENSE
  PERCENTAGE_DISCOUNT
  FIXED_DISCOUNT
  PERIOD_DAY
  PERIOD_WEEK
  PERIOD_MONTH
  PERIOD_YEAR
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum AttachmentContext {
  INVOICE
  PROJECT
  CLIENT
  TICKET
}

enum NotificationType {
  INVOICE_SENT
  INVOICE_VIEWED
  INVOICE_PAID
  INVOICE_OVERDUE
  INVOICE_COMMENT
  ESTIMATE_ACCEPTED
  ESTIMATE_REJECTED
  RECURRING_INVOICE_GENERATED
  TICKET_CREATED
  TICKET_REPLIED
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  PAYMENT_RECEIVED
  SENT
  VIEWED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model Organization {
  id                String   @id
  name              String
  slug              String?  @unique
  logoUrl           String?
  brandColor        String?  @default("#2563eb")
  invoicePrefix     String   @default("INV")
  invoiceNextNumber Int      @default(1)
  taskTimeInterval  Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]
  clients           Client[]
  currencies        Currency[]
  taxes             Tax[]
  items             Item[]
  invoices          Invoice[]
  partialPayments   PartialPayment[]
  payments          Payment[]
  gateways          GatewaySetting[]
  comments          Comment[]
  projects          Project[]
  milestones        Milestone[]
  tasks             ProjectTask[]
  taskStatuses      TaskStatus[]
  projectTemplates  ProjectTemplate[]
  timeEntries       TimeEntry[]
  timers            Timer[]
  expenses                Expense[]
  expenseCategories       ExpenseCategory[]
  expenseSuppliers        ExpenseSupplier[]
  recurringInvoices       RecurringInvoice[]
  creditNoteApplications  CreditNoteApplication[]
  attachments             Attachment[]
  notifications           Notification[]
  auditLogs               AuditLog[]
  tickets                 Ticket[]
  discussions             Discussion[]
}

model User {
  id          String   @id @default(cuid())
  clerkId     String?  @unique
  supabaseId  String?  @unique
  email       String   @unique
  firstName   String?
  lastName    String?
  role        UserRole @default(STAFF)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Client {
  id               String   @id @default(cuid())
  name             String
  email            String?
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  country          String?
  taxId            String?
  notes            String?
  portalToken          String   @unique @default(cuid())
  portalPassphraseHash String?
  isArchived       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  projects       Project[]
  tickets        Ticket[]
}

model Currency {
  id             String   @id @default(cuid())
  code           String
  name           String
  symbol         String
  symbolPosition String   @default("before")
  exchangeRate   Decimal  @default(1) @db.Decimal(18, 6)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  projects       Project[]

  @@unique([organizationId, code])
}

model Tax {
  id         String   @id @default(cuid())
  name       String
  rate       Decimal  @db.Decimal(8, 4)
  isCompound Boolean  @default(false)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organizationId   String
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceLineTaxes InvoiceLineTax[]
  expenses         Expense[]
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  rate        Decimal? @db.Decimal(18, 6)
  unit        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── Invoice Models ───────────────────────────────────────────────────────────

model Invoice {
  id         String        @id @default(cuid())
  number     String
  type       InvoiceType   @default(DETAILED)
  status     InvoiceStatus @default(DRAFT)
  date       DateTime      @default(now())
  dueDate    DateTime?
  lastSent   DateTime?
  lastViewed DateTime?

  // Cached totals (recalculated on every save)
  subtotal      Decimal @default(0) @db.Decimal(20, 10)
  discountTotal Decimal @default(0) @db.Decimal(20, 10)
  taxTotal      Decimal @default(0) @db.Decimal(20, 10)
  total         Decimal @default(0) @db.Decimal(20, 10)

  // Currency
  currencyId   String
  currency     Currency @relation(fields: [currencyId], references: [id])
  exchangeRate Decimal  @default(1) @db.Decimal(10, 5)

  // SIMPLE type only
  simpleAmount Decimal? @db.Decimal(20, 10)

  notes      String?
  isArchived Boolean @default(false)

  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  portalToken String @unique @default(cuid())

  lines           InvoiceLine[]
  partialPayments PartialPayment[]
  payments        Payment[]
  comments        Comment[]
  recurringInvoice        RecurringInvoice?
  creditNotesIssued       CreditNoteApplication[] @relation("CreditNoteSource")
  creditNotesReceived     CreditNoteApplication[] @relation("CreditNoteTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, number])
}

model InvoiceLine {
  id                   String   @id @default(cuid())
  sort                 Int      @default(0)
  lineType             LineType @default(STANDARD)
  name                 String
  description          String?
  qty                  Decimal  @default(1) @db.Decimal(10, 4)
  rate                 Decimal  @default(0) @db.Decimal(20, 10)
  period               Decimal? @db.Decimal(10, 2)
  discount             Decimal  @default(0) @db.Decimal(20, 10)
  discountIsPercentage Boolean  @default(false)

  // Cached calculated values (recomputed on save)
  subtotal Decimal @default(0) @db.Decimal(20, 10)
  taxTotal Decimal @default(0) @db.Decimal(20, 10)
  total    Decimal @default(0) @db.Decimal(20, 10)

  // Source tracking (time entries, expenses, etc.)
  sourceTable String?
  sourceId    String?

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  taxes InvoiceLineTax[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceLineTax {
  id        String  @id @default(cuid())
  taxAmount Decimal @default(0) @db.Decimal(20, 10)

  invoiceLineId String
  invoiceLine   InvoiceLine @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)
  taxId         String
  tax           Tax         @relation(fields: [taxId], references: [id])

  @@unique([invoiceLineId, taxId])
}

model PartialPayment {
  id            String    @id @default(cuid())
  sortOrder     Int       @default(0)
  amount        Decimal   @db.Decimal(20, 10)
  isPercentage  Boolean   @default(false)
  dueDate       DateTime?
  notes         String?
  isPaid        Boolean   @default(false)
  paidAt        DateTime?
  paymentMethod String?
  transactionId String?
  gatewayFee    Decimal   @default(0) @db.Decimal(20, 10)

  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id              String   @id @default(cuid())
  amount          Decimal  @db.Decimal(20, 10)
  gatewayFee      Decimal  @default(0) @db.Decimal(20, 10)
  surchargeAmount Decimal  @default(0) @db.Decimal(20, 10)
  method          String
  transactionId   String?
  notes           String?
  paidAt          DateTime @default(now())

  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model GatewaySetting {
  id          String      @id @default(cuid())
  gatewayType GatewayType
  isEnabled   Boolean     @default(false)
  configJson  String
  surcharge   Decimal     @default(0) @db.Decimal(5, 2)
  label       String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, gatewayType])
}

model Comment {
  id             String   @id @default(cuid())
  body           String
  isPrivate      Boolean  @default(false)
  authorUserId   String?
  authorClientId String?
  authorName     String?

  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Project Models ───────────────────────────────────────────────────────────

model TaskStatus {
  id              String  @id @default(cuid())
  title           String
  backgroundColor String  @default("#e5e7eb")
  fontColor       String  @default("#111827")
  sortOrder       Int     @default(0)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks           ProjectTask[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                  String        @id @default(cuid())
  name                String
  description         String?
  status              ProjectStatus @default(ACTIVE)
  dueDate             DateTime?
  rate                Decimal       @default(0) @db.Decimal(20, 10)
  projectedHours      Float         @default(0)
  isFlatRate          Boolean       @default(false)
  isViewable          Boolean       @default(false)
  isTimesheetViewable Boolean       @default(false)
  currencyId          String
  currency            Currency      @relation(fields: [currencyId], references: [id])
  clientId            String
  client              Client        @relation(fields: [clientId], references: [id])
  organizationId      String
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  milestones          Milestone[]
  tasks               ProjectTask[]
  timeEntries         TimeEntry[]
  expenses            Expense[]
  discussions         Discussion[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Milestone {
  id             String    @id @default(cuid())
  name           String
  description    String?
  color          String    @default("#3b82f6")
  targetDate     DateTime?
  sortOrder      Int       @default(0)
  isViewable     Boolean   @default(false)
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          ProjectTask[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectTask {
  id                  String        @id @default(cuid())
  name                String
  notes               String?
  sortOrder           Int           @default(0)
  isCompleted         Boolean       @default(false)
  isViewable          Boolean       @default(false)
  isTimesheetViewable Boolean       @default(false)
  isFlatRate          Boolean       @default(false)
  projectedHours      Float         @default(0)
  rate                Decimal       @default(0) @db.Decimal(20, 10)
  dueDate             DateTime?
  invoiceLineId       String?
  assignedUserId      String?
  parentId            String?
  parent              ProjectTask?  @relation("TaskChildren", fields: [parentId], references: [id])
  children            ProjectTask[] @relation("TaskChildren")
  milestoneId         String?
  milestone           Milestone?    @relation(fields: [milestoneId], references: [id])
  taskStatusId        String?
  taskStatus          TaskStatus?   @relation(fields: [taskStatusId], references: [id])
  projectId           String
  project             Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId      String
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timeEntries         TimeEntry[]
  timer               Timer?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectTemplate {
  id             String  @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          ProjectTemplateTask[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectTemplateTask {
  id              String  @id @default(cuid())
  name            String
  notes           String?
  sortOrder       Int     @default(0)
  projectedHours  Float   @default(0)
  rate            Decimal @default(0) @db.Decimal(20, 10)
  parentSortOrder Int?
  templateId      String
  template        ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TimeEntry {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  startTime      String?
  endTime        String?
  minutes        Decimal  @db.Decimal(16, 8)
  note           String?
  invoiceLineId  String?
  userId         String
  taskId         String?
  task           ProjectTask? @relation(fields: [taskId], references: [id])
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Timer {
  id             String   @id @default(cuid())
  startedAt      DateTime
  lastModifiedAt DateTime
  currentSeconds Int      @default(0)
  isPaused       Boolean  @default(false)
  isOver         Boolean  @default(false)
  pausesJson     String   @default("[]")
  userId         String
  taskId         String   @unique
  task           ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseCategory {
  id             String  @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses       Expense[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseSupplier {
  id             String  @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses       Expense[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id             String   @id @default(cuid())
  name           String
  description    String?
  qty            Int      @default(1)
  rate           Decimal  @db.Decimal(20, 10)
  dueDate        DateTime?
  paymentDetails String?
  paidAt         DateTime?
  reimbursable   Boolean  @default(false)
  invoiceLineId  String?
  taxId          String?
  tax            Tax?     @relation(fields: [taxId], references: [id])
  categoryId     String?
  category       ExpenseCategory? @relation(fields: [categoryId], references: [id])
  supplierId     String?
  supplier       ExpenseSupplier? @relation(fields: [supplierId], references: [id])
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Recurring Invoices ───────────────────────────────────────────────────────

model RecurringInvoice {
  id              String             @id @default(cuid())
  frequency       RecurringFrequency
  interval        Int                @default(1)
  startDate       DateTime
  nextRunAt       DateTime
  endDate         DateTime?
  maxOccurrences  Int?
  occurrenceCount Int                @default(0)
  isActive        Boolean            @default(true)
  autoSend        Boolean            @default(false)

  invoiceId      String       @unique
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Credit Note Applications ─────────────────────────────────────────────────

model CreditNoteApplication {
  id     String  @id @default(cuid())
  amount Decimal @db.Decimal(20, 10)

  creditNoteId   String
  creditNote     Invoice      @relation("CreditNoteSource", fields: [creditNoteId], references: [id])
  invoiceId      String
  invoice        Invoice      @relation("CreditNoteTarget", fields: [invoiceId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── File Attachments ─────────────────────────────────────────────────────────

model Attachment {
  id           String            @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  storageUrl   String
  context      AttachmentContext
  contextId    String
  uploadedById String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id     String           @id @default(cuid())
  type   NotificationType
  title  String
  body   String
  isRead Boolean          @default(false)
  link   String?
  userId String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entityType  String
  entityId    String
  entityLabel String?
  diff        Json?
  userId      String?
  userLabel   String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Support Tickets ──────────────────────────────────────────────────────────

model Ticket {
  id       String         @id @default(cuid())
  number   Int
  subject  String
  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(NORMAL)

  clientId     String?
  client       Client?         @relation(fields: [clientId], references: [id])
  assignedToId String?
  messages     TicketMessage[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, number])
}

model TicketMessage {
  id         String  @id @default(cuid())
  body       String
  isStaff    Boolean @default(true)
  authorId   String?
  authorName String?

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Project Discussions ──────────────────────────────────────────────────────

model Discussion {
  id         String  @id @default(cuid())
  subject    String
  body       String
  isStaff    Boolean @default(true)
  authorId   String?
  authorName String?

  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  replies        DiscussionReply[]

  createdAt DateTime @default(now())
}

model DiscussionReply {
  id         String  @id @default(cuid())
  body       String
  isStaff    Boolean @default(true)
  authorId   String?
  authorName String?

  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
