// ─── Mileage Tracking ────────────────────────────────────────────────────────

// A single business trip. ratePerMile is snapshotted from the org's
// mileageRatePerMile at creation (overridable per entry) so the deduction
// value of past trips is stable when the org updates its rate.
model MileageEntry {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  miles        Decimal  @db.Decimal(10, 2)
  ratePerMile  Decimal  @db.Decimal(10, 4)
  description  String?
  fromLocation String?
  toLocation   String?
  roundTrip    Boolean  @default(false)
  billable     Boolean  @default(false)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, date])
}

// ─── 1099 / Contractor Tax Pack ───────────────────────────────────────────────

// A contractor (payee) the org pays during the year. Holds the W-9 identity
// fields needed to issue a Form 1099-NEC at year end. The TIN (SSN/EIN) is
// stored encrypted at rest; only the last four digits are kept in clear text
// for display.
model Contractor {
  id                String   @id @default(cuid())
  // ── W-9 identity (Form W-9, Part I) ──
  legalName         String                       // Line 1: name as shown on the tax return
  businessName      String?                      // Line 2: business / disregarded-entity name (DBA)
  taxClassification String?                      // Line 3: "individual", "c_corp", "s_corp", "partnership", "trust", "llc"
  tinType           ContractorTinType?
  tinEncrypted      String?                      // AES-GCM ciphertext of the SSN/EIN
  tinLast4          String?                      // last 4 digits, for display
  // ── Address + contact ──
  email             String?
  phone             String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  zip               String?
  country           String?  @default("US")
  // ── W-9 collection ──
  w9Status          W9Status @default(NOT_REQUESTED)
  w9DocumentPath    String?                      // private storage path of the signed W-9 PDF
  w9ReceivedAt      DateTime?
  // ── 1099 eligibility ──
  // Corporations (C/S) are generally exempt from 1099-NEC reporting. When the
  // user marks a payee exempt, it is excluded from the 1099 pack regardless of
  // how much was paid.
  exemptFrom1099    Boolean  @default(false)
  notes             String?
  isArchived        Boolean  @default(false)

  // ── Self-service contractor portal ──
  // Opt-in per contractor. The token is the bearer secret for the portal URL
  // (same model as the client invoice portal token); the org enables access and
  // shares the link so the contractor can view their payment history, submit a
  // W-9, and download their 1099-NEC without an account.
  portalEnabled     Boolean  @default(false)
  portalToken       String   @unique @default(uuid(4))

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payments       ContractorPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, isArchived])
}

// A single payment made to a contractor. The reportable flag controls whether
// the amount rolls up into the contractor's 1099-NEC box 1 total.
model ContractorPayment {
  id             String                  @id @default(cuid())
  amount         Decimal                 @db.Decimal(20, 10)
  paidAt         DateTime
  method         ContractorPaymentMethod @default(CHECK)
  memo           String?
  reference      String?                                       // check #, ACH trace, txn id
  // Defaults follow the method: CARD / THIRD_PARTY payments are reported by the
  // processor on a 1099-K and so are not reportable here; everything else is.
  reportable     Boolean                 @default(true)
  // Optional link back to an Expense, so a payment recorded in the expense
  // ledger can also be tracked against the contractor's 1099 total.
  expenseId      String?

  contractorId   String
  contractor     Contractor              @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, paidAt])
  @@index([contractorId])
}

// ─── Recurring Invoices ───────────────────────────────────────────────────────

model RecurringInvoice {
  id              String             @id @default(cuid())
  frequency       RecurringFrequency
  interval        Int                @default(1)
  startDate       DateTime
  nextRunAt       DateTime
  endDate         DateTime?
  maxOccurrences  Int?
  occurrenceCount Int                @default(0)
  isActive        Boolean            @default(true)
  autoSend        Boolean            @default(false)
  autoCharge      Boolean            @default(false)
  // Optional anchor for MONTHLY/YEARLY schedules. 1-31; values past the
  // last day of a given month clamp to the last day (Feb 30 → Feb 28/29).
  // Null falls back to startDate's day-of-month.
  dayOfMonth      Int?
  // IANA timezone for computing nextRunAt boundaries. Null = UTC. Lets
  // an org running in America/New_York fire monthly invoices at local
  // midnight instead of 7-8pm the previous day.
  timezone        String?

  invoiceId      String       @unique
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Credit Note Applications ─────────────────────────────────────────────────

model CreditNoteApplication {
  id     String  @id @default(cuid())
  amount Decimal @db.Decimal(20, 10)

  creditNoteId   String
  creditNote     Invoice      @relation("CreditNoteSource", fields: [creditNoteId], references: [id])
  invoiceId      String
  invoice        Invoice      @relation("CreditNoteTarget", fields: [invoiceId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── File Attachments ─────────────────────────────────────────────────────────

model Attachment {
