  feeType   String
  feeRate   Decimal  @db.Decimal(10, 4)
  isWaived  Boolean  @default(false)
  waivedAt  DateTime?
  waivedBy  String?
  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
