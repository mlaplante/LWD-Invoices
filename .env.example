# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lwd_invoices"

# Supabase (Authentication & File Storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Email (Resend)
RESEND_API_KEY="re_your-api-key"
RESEND_FROM_EMAIL="invoices@yourdomain.com"
# Optional: enables /api/webhooks/resend for delivery/open/click tracking.
# Configure a webhook endpoint in the Resend dashboard pointing at
# https://your-app/api/webhooks/resend, then paste the signing secret here.
RESEND_WEBHOOK_SECRET="whsec_your-resend-webhook-secret"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Security
# Generate with: openssl rand -hex 32
GATEWAY_ENCRYPTION_KEY="your-64-character-hex-key-here-generate-with-openssl-rand-hex-32"

# Dedicated HMAC secret for public-portal session cookies. Optional — when
# unset, falls back to SUPABASE_SERVICE_ROLE_KEY. Strongly recommended in
# production so the service-role key isn't also a cookie-forgery key.
# Generate with: openssl rand -hex 32
PORTAL_SESSION_SECRET="your-64-character-hex-key-here-generate-with-openssl-rand-hex-32"

# Background Jobs (Inngest) - Optional but recommended
INNGEST_SIGNING_KEY="your-inngest-signing-key"
INNGEST_EVENT_KEY="your-inngest-event-key"

# Payment Gateways - Optional
# Stripe
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# PayPal
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"


# AI Features - Optional
OPENAI_API_KEY="sk-your-openai-key"
# Gemini has a free API tier (note: free-tier data may be used by Google to
# improve their products — review before sending sensitive data).
GEMINI_API_KEY="your-gemini-api-key"
ANTHROPIC_API_KEY="sk-ant...-key"

# Receipt scanning supports three providers. Set RECEIPT_OCR_PROVIDER to pick
# one explicitly; otherwise it falls back to whichever key is present
# (OpenAI > Gemini > Anthropic). OpenAI and Gemini handle images + PDFs;
# Anthropic is image-only.
RECEIPT_OCR_PROVIDER="openai"
# Optional: ordered Gemini model fallback chain for receipt OCR. On a 429
# (rate-limit/quota) the next model is tried. Leave unset for the built-in
# default ("gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash").
# GEMINI_OCR_MODELS="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"

# Natural-language invoice drafting. INVOICE_PARSER_PROVIDER picks the model
# family (defaults to openai when unset; falls back to gemini if only
# GEMINI_API_KEY is set).
INVOICE_PARSER_PROVIDER="openai"
OPENAI_INVOICE_PARSER_MODEL="gpt-4.1-mini"
# Ordered Gemini model fallback chain for invoice drafting (same semantics as
# GEMINI_OCR_MODELS). On a 429 the next model is tried. Leave unset for the
# built-in default ("gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash").
# GEMINI_INVOICE_PARSER_MODELS="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"

# Smart reminder drafting uses OpenAI or Gemini. Set REMINDER_AI_PROVIDER to
# pick one explicitly; otherwise it uses whichever key is present (OpenAI > Gemini).
# Model config is optional. OPENAI_REMINDER_MODEL overrides the OpenAI model;
# GEMINI_REMINDER_MODELS is an ordered Gemini fallback chain (429 → next model,
# same behavior as GEMINI_OCR_MODELS). Defaults: gpt-4o-mini /
# "gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash".
REMINDER_AI_PROVIDER="openai"
OPENAI_REMINDER_MODEL="gpt-4o-mini"
# GEMINI_REMINDER_MODELS="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"

# Development
NODE_ENV="development"
SKIP_ENV_VALIDATION="false"
