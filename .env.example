# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lwd_invoices"

# Supabase (Authentication & File Storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Email (Resend)
RESEND_API_KEY="re_your-api-key"
RESEND_FROM_EMAIL="invoices@yourdomain.com"
# Optional: enables /api/webhooks/resend for delivery/open/click tracking.
# Configure a webhook endpoint in the Resend dashboard pointing at
# https://your-app/api/webhooks/resend, then paste the signing secret here.
RESEND_WEBHOOK_SECRET="whsec_your-resend-webhook-secret"
# Optional: inbound email threading. Set RESEND_INBOUND_DOMAIN to the domain you
# configured for inbound parsing (e.g. inbound.yourdomain.com); invoice emails
# then get a Reply-To of reply+<invoiceId>@<domain> so client replies route to
# /api/webhooks/inbound-email and thread onto the invoice + a support ticket.
# RESEND_INBOUND_WEBHOOK_SECRET is the Svix signing secret for that webhook.
RESEND_INBOUND_DOMAIN="inbound.yourdomain.com"
RESEND_INBOUND_WEBHOOK_SECRET="whsec_your-inbound-webhook-secret"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional: shared secret used by the scheduled warmup ping.
# Generate with: openssl rand -hex 32
WARMUP_SECRET="your-64-character-hex-key-here-generate-with-openssl-rand-hex-32"

# Security
# Generate with: openssl rand -hex 32
GATEWAY_ENCRYPTION_KEY="your-64-character-hex-key-here-generate-with-openssl-rand-hex-32"

# Dedicated HMAC secret for public-portal session cookies. Optional — when
# unset, falls back to SUPABASE_SERVICE_ROLE_KEY. Strongly recommended in
# production so the service-role key isn't also a cookie-forgery key.
# Generate with: openssl rand -hex 32
PORTAL_SESSION_SECRET="your-64-character-hex-key-here-generate-with-openssl-rand-hex-32"

# Background Jobs (Inngest) - Optional but recommended
INNGEST_SIGNING_KEY="your-inngest-signing-key"
INNGEST_EVENT_KEY="your-inngest-event-key"

# Payment Gateways - Optional
# Stripe
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# PayPal
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"


# AI Features - Optional
OPENAI_API_KEY="sk-your-openai-key"
# Gemini has a free API tier (note: free-tier data may be used by Google to
# improve their products — review before sending sensitive data).
GEMINI_API_KEY="your-gemini-api-key"
ANTHROPIC_API_KEY="sk-ant...-key"
# "Ask your books" assistant (tool-calling agent). Defaults to GEMINI first
# (function-calling + model-fallback chain) when GEMINI_API_KEY is set, else
# Anthropic. Pin a provider with ASSISTANT_AI_PROVIDER ("gemini" | "anthropic").
# ASSISTANT_AI_PROVIDER="gemini"
# GEMINI_AGENT_MODELS="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"
# Model for the Anthropic fallback path (defaults to claude-opus-4-8).
ANTHROPIC_AGENT_MODEL="claude-opus-4-8"

# AI provider precedence: the AI features (receipt OCR, natural-language
# invoicing, smart reminders, cash-flow narrative) default to GEMINI first when
# GEMINI_API_KEY is set — Gemini runs an ordered model-fallback chain that
# retries the next model on a 429 (rate-limit/quota). They fall back to OpenAI
# (then Anthropic, for OCR) when Gemini isn't configured. Set the per-feature
# *_PROVIDER vars below only to pin a specific provider.

# Receipt scanning supports three providers. Leave RECEIPT_OCR_PROVIDER unset to
# use the Gemini-first default; set it to pin one explicitly. Gemini and OpenAI
# handle images + PDFs; Anthropic is image-only.
# RECEIPT_OCR_PROVIDER="gemini"
# Optional: ordered Gemini model fallback chain for receipt OCR. On a 429
# (rate-limit/quota) the next model is tried. Leave unset for the built-in
# default ("gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash").
# GEMINI_OCR_MODELS="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"

# Natural-language invoice drafting. Leave INVOICE_PARSER_PROVIDER unset to use
# the Gemini-first default (falls back to OpenAI when only OPENAI_API_KEY is
# set); set it to pin a provider.
# INVOICE_PARSER_PROVIDER="gemini"
OPENAI_INVOICE_PARSER_MODEL="gpt-4.1-mini"
# Ordered Gemini model fallback chain for invoice drafting (same semantics as
# GEMINI_OCR_MODELS). On a 429 the next model is tried. Leave unset for the
# built-in default ("gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash").
# GEMINI_INVOICE_PARSER_MODELS="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"

# Smart reminder drafting uses Gemini or OpenAI. Leave REMINDER_AI_PROVIDER
# unset to use the Gemini-first default (falls back to OpenAI when only its key
# is set); set it to pin a provider. OPENAI_REMINDER_MODEL overrides the OpenAI
# model; GEMINI_REMINDER_MODELS is an ordered Gemini fallback chain (429 → next
# model). Defaults: gpt-4o-mini / "gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash".
# REMINDER_AI_PROVIDER="gemini"
OPENAI_REMINDER_MODEL="gpt-4o-mini"
# GEMINI_REMINDER_MODELS="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"

# Cash-flow narrative (dashboard AI insights). Defaults to Gemini first, then
# OpenAI, then a deterministic summary. GEMINI_CASHFLOW_MODELS is an ordered
# Gemini fallback chain (429 → next model). Leave unset for the built-in default.
# GEMINI_CASHFLOW_MODELS="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"

# AI invoice reviewer (unclear-line-description check). Defaults to Gemini.
# INVOICE_REVIEW_AI_PROVIDER=gemini
# GEMINI_INVOICE_REVIEW_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash

# AI expense categorization (LLM fallback for new suppliers). Defaults to Gemini.
# EXPENSE_CATEGORY_AI_PROVIDER=gemini
# GEMINI_EXPENSE_CATEGORY_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash

# AI proposal generator. Defaults to Gemini.
# PROPOSAL_AI_PROVIDER=gemini
# GEMINI_PROPOSAL_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash

# Development
NODE_ENV="development"
SKIP_ENV_VALIDATION="false"
